<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>小黄人集市 · 主题商店（多板块+评论）</title>
    <!-- 字体与图标库 (Font Awesome) 增加趣味图标 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'Comic Sans MS', 'Chalkboard SE', Roboto, sans-serif;
        }

        body {
            background: linear-gradient(145deg, #fdea4d 0%, #ffcd3a 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            overflow-x: hidden;
        }

        /* 漂浮小黄人背景装饰 */
        .minion-bg-icon {
            position: absolute;
            opacity: 0.15;
            pointer-events: none;
            z-index: 1;
            font-size: 6rem;
            user-select: none;
        }

        .bg-icon-1 { top: 20px; left: 10px; transform: rotate(-10deg); }
        .bg-icon-2 { bottom: 40px; right: 20px; transform: rotate(15deg); }
        .bg-icon-3 { top: 40%; left: 80%; font-size: 5rem; }
        .bg-icon-4 { bottom: 15%; left: 5%; font-size: 7rem; opacity: 0.1; }

        /* 主面板 */
        .shop-container {
            position: relative;
            z-index: 10;
            max-width: 1300px;
            width: 95%;
            margin: 20px auto;
            background-color: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(8px);
            border-radius: 60px 60px 40px 40px;
            box-shadow: 0 25px 40px rgba(0, 0, 0, 0.25), 0 0 0 6px #0b385f, 0 0 0 12px #f5e56b;
            padding: 20px 25px 40px 25px;
            border: 4px dashed #ff9900;
        }

        /* 头部 — 小黄人护目镜风格 */
        .header {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            background: #1f5e8e;
            background: linear-gradient(135deg, #1167a8, #0a4c7a);
            margin: -20px -25px 20px -25px;
            padding: 25px 35px;
            border-radius: 60px 60px 30px 30px;
            box-shadow: inset 0 -6px 0 #083752, 0 10px 15px rgba(0,0,0,0.2);
            color: white;
            border-bottom: 6px solid #f3c74d;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .minion-avatar {
            background: #f5e56b;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            border: 4px solid #222;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3.5rem;
            box-shadow: 0 0 0 5px #ffe185;
        }

        .shop-name h1 {
            font-size: 2.8rem;
            font-weight: 900;
            text-shadow: 5px 5px 0 #0b385f, 2px 2px 0 #f3c74d;
            letter-spacing: 3px;
            color: #ffde6b;
            line-height: 1.1;
        }

        .shop-name p {
            font-size: 1.1rem;
            background: #222;
            display: inline-block;
            padding: 5px 20px;
            border-radius: 100px;
            color: #fae100;
            border: 2px solid white;
        }

        .cart-summary {
            background: #f3c74d;
            padding: 15px 30px;
            border-radius: 50px;
            color: #1f3a4b;
            font-weight: bold;
            font-size: 1.5rem;
            border: 4px solid white;
            box-shadow: 0 6px 0 #a5751e;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: 0.2s;
            cursor: pointer;
        }

        .cart-summary i {
            font-size: 2rem;
            color: #1f5e8e;
        }

        .cart-summary:hover {
            transform: translateY(-3px);
            box-shadow: 0 9px 0 #a5751e;
        }

        /* 特色小黄人标语 */
        .promo-banner {
            background: #fae45b;
            border-radius: 100px;
            padding: 15px 30px;
            margin: 20px 0 30px;
            text-align: center;
            border: 5px solid white;
            outline: 3px solid #347aab;
            font-size: 1.8rem;
            font-weight: bold;
            color: #1c4a6e;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
            box-shadow: 0 10px 0 #b37b2e;
        }

        .promo-banner span {
            background: #13638f;
            color: white;
            padding: 10px 20px;
            border-radius: 40px;
            font-size: 1.4rem;
        }

        /* 板块分类标签 */
        .section-tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin: 25px 0 15px;
            justify-content: center;
        }
        .section-tab {
            background: #f3c74d;
            padding: 12px 28px;
            border-radius: 50px;
            font-weight: bold;
            font-size: 1.4rem;
            border: 4px solid white;
            box-shadow: 0 5px 0 #b37b2e;
            transition: 0.1s;
            cursor: pointer;
            color: #1f3a4b;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .section-tab.active {
            background: #1f5e8e;
            color: white;
            box-shadow: 0 5px 0 #083752;
            transform: translateY(-2px);
        }
        .section-tab i { font-size: 1.6rem; }

        /* 产品网格 — 多板块共用网格 */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 30px;
            margin: 30px 0;
        }

        .product-card {
            background: white;
            border-radius: 50px 50px 30px 30px;
            padding: 25px 20px 20px;
            box-shadow: 0 15px 0 #ca9219, 0 20px 20px rgba(0, 0, 0, 0.2);
            border: 5px solid #1f5e8e;
            transition: 0.2s;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 0 #ca9219, 0 25px 30px rgba(0, 0, 0, 0.2);
        }

        .minion-stamp {
            position: absolute;
            top: -15px;
            right: -10px;
            background: #ed3b3b;
            color: white;
            font-size: 1.4rem;
            padding: 10px 15px;
            border-radius: 40px;
            border: 3px solid white;
            transform: rotate(8deg);
            font-weight: bold;
            box-shadow: 0 5px 0 #911717;
        }

        .product-image {
            font-size: 6rem;
            background: #f5e56b;
            border-radius: 50%;
            width: 140px;
            height: 140px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            border: 6px solid #083752;
            box-shadow: inset 0 -8px 0 #b37b2e;
            color: #2b2b2b;
        }

        .product-info h3 {
            font-size: 1.9rem;
            font-weight: 900;
            color: #003057;
            margin-bottom: 5px;
            text-align: center;
        }

        .product-info .desc {
            font-size: 1rem;
            color: #2f4858;
            background: #fef7d2;
            padding: 8px 12px;
            border-radius: 50px;
            margin: 10px 0;
            border: 2px dashed #13638f;
            text-align: center;
        }

        .price-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 15px 0 10px;
            background: #e2f0ff;
            padding: 12px 15px;
            border-radius: 40px;
            border: 2px solid #0b385f;
        }

        .price {
            font-size: 2.2rem;
            font-weight: 900;
            color: #b44c10;
        }
        .price small {
            font-size: 1.2rem;
            color: #3c5a75;
        }

        .add-to-cart {
            background: #f3c74d;
            border: none;
            font-size: 1.4rem;
            font-weight: bold;
            padding: 12px 20px;
            border-radius: 40px;
            border: 4px solid white;
            box-shadow: 0 6px 0 #b37b2e;
            cursor: pointer;
            transition: 0.08s linear;
            color: #1f3a4b;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            width: 100%;
        }

        .add-to-cart:active {
            transform: translateY(6px);
            box-shadow: 0 2px 0 #b37b2e;
        }

        .add-to-cart i {
            font-size: 1.8rem;
        }

        /* 购物车详情面板 */
        .cart-panel {
            background: #fffaeb;
            border-radius: 70px 70px 40px 40px;
            padding: 30px 30px 20px;
            margin-top: 40px;
            border: 6px solid #0f4c75;
            box-shadow: inset 0 0 0 5px #fedb83, 0 15px 0 #0a3852;
        }

        .cart-title {
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 2.5rem;
            color: #022b49;
            margin-bottom: 20px;
            background: #ffe166;
            padding: 10px 30px;
            border-radius: 60px;
            border: 4px solid white;
            display: inline-block;
        }

        .cart-items {
            min-height: 80px;
            background: #c0e2ff;
            border-radius: 60px;
            padding: 30px;
            border: 4px dashed #1f5e8e;
            margin-bottom: 25px;
            font-size: 1.4rem;
            color: #00263b;
        }

        .cart-item-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: white;
            padding: 15px 25px;
            border-radius: 100px;
            margin-bottom: 15px;
            border: 3px solid #13638f;
            font-weight: bold;
        }

        .cart-item-name {
            font-size: 1.6rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .cart-item-qty {
            background: #fedb83;
            padding: 8px 18px;
            border-radius: 40px;
            font-size: 1.3rem;
        }

        .cart-item-price {
            color: #b33f00;
        }

        .remove-item {
            background: none;
            border: 2px solid red;
            color: red;
            border-radius: 30px;
            padding: 8px 16px;
            font-size: 1.2rem;
            cursor: pointer;
            font-weight: bold;
            transition: 0.1s;
        }
        .remove-item:hover {
            background: red;
            color: white;
        }

        .cart-total {
            font-size: 2.5rem;
            font-weight: 900;
            background: #1f5e8e;
            color: #ffde00;
            padding: 20px 30px;
            border-radius: 60px;
            border: 6px solid white;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .checkout-btn {
            background: #fea82f;
            border: none;
            padding: 15px 45px;
            border-radius: 50px;
            font-size: 2rem;
            font-weight: bold;
            border: 5px solid white;
            box-shadow: 0 8px 0 #9e601d;
            cursor: pointer;
            color: #1f3a4b;
            transition: 0.1s;
            display: flex;
            align-items: center;
            gap: 20px;
        }
        .checkout-btn:active {
            transform: translateY(8px);
            box-shadow: 0 2px 0 #9e601d;
        }

        .empty-cart-msg {
            text-align: center;
            font-size: 2rem;
            color: #26648b;
            opacity: 0.8;
        }

        /* ========= 评论区全新板块 ========= */
        .comment-section {
            background: #fffaeb;
            border-radius: 70px 70px 40px 40px;
            padding: 30px 30px 20px;
            margin-top: 50px;
            border: 6px solid #0f4c75;
            box-shadow: inset 0 0 0 5px #fedb83, 0 15px 0 #0a3852;
        }
        .comment-title {
            font-size: 2.5rem;
            color: #022b49;
            background: #ffe166;
            padding: 10px 40px;
            border-radius: 60px;
            border: 4px solid white;
            display: inline-flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 30px;
        }
        .comment-form {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 30px;
            background: #c0e2ff;
            padding: 25px;
            border-radius: 70px;
            border: 4px solid #1f5e8e;
        }
        .comment-form input, .comment-form textarea {
            flex: 1 1 200px;
            padding: 18px 25px;
            border-radius: 60px;
            border: 3px solid #13638f;
            font-size: 1.2rem;
            background: white;
            outline: none;
        }
        .comment-form textarea {
            min-width: 100%;
            resize: vertical;
        }
        .comment-form button {
            background: #f3c74d;
            border: none;
            padding: 15px 35px;
            border-radius: 50px;
            font-size: 1.8rem;
            font-weight: bold;
            border: 4px solid white;
            box-shadow: 0 6px 0 #b37b2e;
            cursor: pointer;
            color: #1f3a4b;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: 0.1s;
        }
        .comment-form button:active {
            transform: translateY(6px);
            box-shadow: 0 2px 0 #b37b2e;
        }

        .comment-list {
            background: #fff5cf;
            border-radius: 70px;
            padding: 25px;
            border: 5px dashed #1f5e8e;
        }
        .comment-item {
            background: white;
            border-radius: 50px;
            padding: 20px 30px;
            margin-bottom: 20px;
            border: 3px solid #13638f;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
        }
        .comment-content {
            flex: 3 1 300px;
        }
        .comment-author {
            font-weight: 900;
            color: #003057;
            font-size: 1.6rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .comment-text {
            font-size: 1.3rem;
            color: #2f4858;
            margin: 8px 0 4px;
            word-break: break-word;
        }
        .comment-date {
            font-size: 1rem;
            color: #7a8c9e;
        }
        .like-area {
            flex: 0 0 auto;
            display: flex;
            align-items: center;
            gap: 15px;
            background: #fdea4d;
            padding: 12px 20px;
            border-radius: 40px;
            border: 2px solid white;
        }
        .like-btn {
            background: none;
            border: none;
            font-size: 2rem;
            cursor: pointer;
            color: #b33f00;
            transition: 0.1s;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .like-btn:hover { transform: scale(1.2); }
        .like-count {
            font-size: 1.6rem;
            font-weight: bold;
            color: #1f3a4b;
        }

        /* 底部小黄人信息 */
        .footer-note {
            margin-top: 30px;
            text-align: center;
            color: #003459;
            font-size: 1.2rem;
            font-weight: bold;
            background: rgba(255, 255, 255, 0.6);
            padding: 15px;
            border-radius: 100px;
        }

        /* 响应式微调 */
        @media (max-width: 650px) {
            .header { flex-direction: column; align-items: start; gap: 15px; }
            .shop-name h1 { font-size: 2rem; }
            .promo-banner { font-size: 1.2rem; }
        }
    </style>
</head>
<body>
    <!-- 漂浮小黄人装饰 -->
    <div class="minion-bg-icon bg-icon-1">🐤</div>
    <div class="minion-bg-icon bg-icon-2">🍌</div>
    <div class="minion-bg-icon bg-icon-3">👓</div>
    <div class="minion-bg-icon bg-icon-4">💛</div>

    <div class="shop-container">
        <!-- 头部区域 -->
        <div class="header">
            <div class="logo-area">
                <div class="minion-avatar">
                    <span>🐤</span>
                </div>
                <div class="shop-name">
                    <h1>MINION BAZAR</h1>
                    <p><i class="fa-solid fa-banana"></i>  BANANA!  <i class="fa-solid fa-banana"></i></p>
                </div>
            </div>
            <div class="cart-summary" id="cartSummary">
                <i class="fa-solid fa-cart-shopping"></i>
                <span id="cartCount">0</span> 件 · <span id="cartTotalPrice">0</span>
            </div>
        </div>

        <!-- 促销横幅 -->
        <div class="promo-banner">
            <span>🍌🍌</span>  POCO TIENDA ·  ALL FOR BANANA!  <span>🍌🍌</span>
        </div>

        <!-- 多板块切换标签 -->
        <div class="section-tabs">
            <div class="section-tab active" data-section="general"><i class="fa-solid fa-store"></i> 全部集市</div>
            <div class="section-tab" data-section="toys"><i class="fa-solid fa-puzzle-piece"></i> 扭蛋/公仔</div>
            <div class="section-tab" data-section="clothes"><i class="fa-solid fa-shirt"></i> 工装/配饰</div>
            <div class="section-tab" data-section="blindbox"><i class="fa-solid fa-gift"></i> 盲盒专区</div>
        </div>

        <!-- 商品列表网格 (动态渲染) -->
        <div id="productList" class="product-grid"></div>

        <!-- 购物车详情面板 -->
        <div class="cart-panel" id="cartPanel">
            <div class="cart-title">
                <i class="fa-solid fa-cart-flatbed"></i> 你的香蕉篮子
            </div>
            <div class="cart-items" id="cartItemsContainer">
                <div class="empty-cart-msg">🛒 空空如也～ 选个小黄人宝贝吧！</div>
            </div>
            <div class="cart-total">
                <span>总计：🍌 <span id="totalCartAmount">0</span> 元</span>
                <button class="checkout-btn" id="checkoutBtn"><i class="fa-regular fa-face-smile"></i> 买买买 <i class="fa-regular fa-face-smile-wink"></i></button>
            </div>
        </div>

        <!-- ========= 全新评论区板块 ========= -->
        <div class="comment-section" id="commentSection">
            <div class="comment-title">
                <i class="fa-regular fa-comments"></i> 小黄人唠嗑区
            </div>
            <!-- 发表评论表单 -->
            <div class="comment-form">
                <input type="text" id="commentName" placeholder="你的昵称 (如: 凯文)" value="鲍勃">
                <textarea id="commentText" placeholder="说点啥... 比如：香蕉好好吃！" rows="2">我喜欢那只公仔！</textarea>
                <button id="postCommentBtn"><i class="fa-regular fa-paper-plane"></i> 发射评论</button>
            </div>
            <!-- 评论列表容器 -->
            <div class="comment-list" id="commentListContainer">
                <!-- 动态评论会加载到这里 -->
            </div>
        </div>

        <!-- 小黄人脚注 -->
        <div class="footer-note">
            <i class="fa-regular fa-copyright"></i>  BEE-DO! BEE-DO!  小黄人官方主题商店 (多板块+评论版)
        </div>
    </div>

    <!-- 固定小黄人 -->
    <div style="position:fixed; bottom:15px; right:15px; background:#ffd966; border-radius:50%; width:60px; height:60px; display:flex; align-items:center; justify-content:center; font-size:2.5rem; border:4px solid white; box-shadow:0 8px 0 #b87c1b; z-index:999;">
        🐥
    </div>

    <script>
        (function() {
            // ---------- 丰富商品数据 (多板块) ----------
            const products = [
                // 通用/全部集市 (id 1~6 原先保留，新增更多)
                { id: 1, name: '🐤 小黄人公仔', desc: '15cm 摇头公仔, 带香蕉', price: 129, icon: '🧸', section: 'toys' },
                { id: 2, name: '🍌 香蕉抱枕', desc: '超柔软香蕉抱枕 1.2m', price: 189, icon: '🛋️', section: 'general' },
                { id: 3, name: '👓 护目镜水杯', desc: '双层玻璃杯 印有护目镜', price: 99, icon: '🥤', section: 'general' },
                { id: 4, name: '💛 连体工装裤', desc: '儿童/成人均码 牛仔蓝', price: 359, icon: '👖', section: 'clothes' },
                { id: 5, name: '🎸 斯图尔特玩偶', desc: '弹吉他限定版', price: 159, icon: '🎤', section: 'toys' },
                { id: 6, name: '📚 反派故事书', desc: '小黄人大电影绘本', price: 79, icon: '📖', section: 'general' },
                // 新增玩具/扭蛋
                { id: 7, name: '🐣 扭蛋·迷你兵团', desc: '随机一款小黄人扭蛋', price: 39, icon: '🥚', section: 'blindbox' },
                { id: 8, name: '🎰 香蕉扭蛋机', desc: '迷你扭蛋机(含3个蛋)', price: 229, icon: '🎮', section: 'toys' },
                { id: 9, name: '🧸 凯文发声玩偶', desc: '按压会说 Banana', price: 279, icon: '🔊', section: 'toys' },
                // 新增盲盒专区
                { id: 10, name: '🎁 电影系列盲盒', desc: '12款基础+隐藏', price: 69, icon: '📦', section: 'blindbox' },
                { id: 11, name: '👀 护目镜盲袋', desc: '超迷你眼镜收集', price: 29, icon: '👓', section: 'blindbox' },
                { id: 12, name: '⭐ 反派BOB盲盒', desc: '带小熊的鲍勃', price: 89, icon: '🧸', section: 'blindbox' },
                // 新增工装配饰
                { id: 13, name: '🧢 小黄人棒球帽', desc: '黄色刺绣 可调节', price: 149, icon: '🧢', section: 'clothes' },
                { id: 14, name: '👕 格鲁家族T恤', desc: '黑色/黄色 印花', price: 199, icon: '👕', section: 'clothes' },
                { id: 15, name: '👜 香蕉斜挎包', desc: '软萌香蕉造型包', price: 139, icon: '👜', section: 'clothes' },
                { id: 16, name: '🧦 三花短袜', desc: '小黄人图案三双装', price: 59, icon: '🧦', section: 'clothes' }
            ];

            // ----- 购物车数据 -----
            let cart = {};

            // ----- DOM 元素 -----
            const productListEl = document.getElementById('productList');
            const cartItemsContainer = document.getElementById('cartItemsContainer');
            const cartCountSpan = document.getElementById('cartCount');
            const cartTotalPriceSpan = document.getElementById('cartTotalPrice');
            const totalCartAmountSpan = document.getElementById('totalCartAmount');
            const sectionTabs = document.querySelectorAll('.section-tab');

            // ----- 当前选中的板块 (默认 'general' 但保留'all'效果) 我们使用'all'代表全部，但标签上general为全部集市。将general映射为全显示-----
            let currentSection = 'general'; 

            // ----- 辅助函数 更新购物车UI (与之前一样)-----
            function refreshCartUI() {
                let totalItems = 0;
                let totalAmount = 0;
                for (let id in cart) {
                    const item = cart[id];
                    totalItems += item.quantity;
                    totalAmount += item.quantity * item.price;
                }
                cartCountSpan.textContent = totalItems;
                cartTotalPriceSpan.textContent = totalAmount;
                totalCartAmountSpan.textContent = totalAmount;

                if (totalItems === 0) {
                    cartItemsContainer.innerHTML = `<div class="empty-cart-msg">🛒 空空如也～ 选个小黄人宝贝吧！</div>`;
                } else {
                    let htmlStr = '';
                    for (let id in cart) {
                        const item = cart[id];
                        htmlStr += `
                            <div class="cart-item-row" data-cart-id="${id}">
                                <div class="cart-item-name">
                                    <span>${item.icon || '🐤'}</span> ${item.name} 
                                    <span class="cart-item-qty">✖️ ${item.quantity}</span>
                                </div>
                                <div class="cart-item-price">💰 ${item.price * item.quantity} 元</div>
                                <button class="remove-item" data-id="${id}"><i class="fa-solid fa-trash-can"></i> 移除</button>
                            </div>
                        `;
                    }
                    cartItemsContainer.innerHTML = htmlStr;
                    document.querySelectorAll('.remove-item').forEach(btn => {
                        btn.addEventListener('click', (e) => {
                            const id = btn.getAttribute('data-id');
                            removeFromCart(id);
                        });
                    });
                }
            }

            function addToCart(product) {
                const id = product.id;
                if (cart[id]) {
                    cart[id].quantity += 1;
                } else {
                    cart[id] = {
                        id: id,
                        name: product.name,
                        price: product.price,
                        quantity: 1,
                        icon: product.icon
                    };
                }
                refreshCartUI();
            }

            function removeFromCart(productId) {
                if (cart[productId]) {
                    delete cart[productId];
                }
                refreshCartUI();
            }

            // ----- 根据板块渲染商品 -----
            function renderProducts() {
                let filtered = products;
                if (currentSection !== 'general') {
                    filtered = products.filter(p => p.section === currentSection);
                }
                // 如果过滤后没有商品，可展示占位
                let productHTML = '';
                filtered.forEach(prod => {
                    productHTML += `
                        <div class="product-card" data-id="${prod.id}">
                            <div class="minion-stamp"><i class="fa-regular fa-star"></i> BANANA</div>
                            <div class="product-image">
                                ${prod.icon || '🐥'}
                            </div>
                            <div class="product-info">
                                <h3>${prod.name}</h3>
                                <div class="desc">${prod.desc}</div>
                                <div class="price-row">
                                    <span class="price"><small>¥</small>${prod.price}</span>
                                    <span style="font-size: 1.5rem;">🐥</span>
                                </div>
                                <button class="add-to-cart" data-id="${prod.id}"><i class="fa-solid fa-cart-plus"></i> 加入篮子</button>
                            </div>
                        </div>
                    `;
                });
                if (filtered.length === 0) {
                    productListEl.innerHTML = '<div style="grid-column:1/-1; text-align:center; font-size:2rem; background:white; border-radius:60px; padding:50px;">🍌 这个板块空空如也～ 逛逛别的吧！</div>';
                } else {
                    productListEl.innerHTML = productHTML;
                }

                // 重新绑定加入购物车事件
                document.querySelectorAll('.add-to-cart').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const prodId = parseInt(btn.getAttribute('data-id'));
                        const product = products.find(p => p.id === prodId);
                        if (product) {
                            addToCart(product);
                            btn.style.backgroundColor = '#b8d93e';
                            setTimeout(() => btn.style.backgroundColor = '', 120);
                        }
                    });
                });
            }

            // ----- 切换板块 -----
            sectionTabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    sectionTabs.forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    currentSection = tab.getAttribute('data-section');
                    renderProducts();
                });
            });

            // ----- 结账按钮 -----
            document.getElementById('checkoutBtn').addEventListener('click', function() {
                if (Object.keys(cart).length === 0) {
                    alert('🍌 先选个小黄人宝贝再结账呀～');
                } else {
                    let total = totalCartAmountSpan.textContent;
                    alert(`🧾 模拟结账成功！ 你消费了 ${total} 元香蕉币，小黄人很开心！ 🎉`);
                }
            });

            // 点击购物车滚动
            document.getElementById('cartSummary').addEventListener('click', function() {
                document.getElementById('cartPanel').scrollIntoView({ behavior: 'smooth' });
            });

            // ---------- 评论系统 (保存评论且他人可见、可点赞) ----------
            // 评论数据存储在 localStorage 模拟持久化 (他人可见: 同浏览器可共享)
            let comments = [];

            function loadComments() {
                const stored = localStorage.getItem('minion_comments');
                if (stored) {
                    try { comments = JSON.parse(stored); } catch(e){ comments = []; }
                } else {
                    // 两条默认评论
                    comments = [
                        { id: Date.now()-10000, author: '凯文', text: '香蕉抱枕太舒服了！已购🍌', likes: 5, date: new Date().toLocaleString() },
                        { id: Date.now()-5000, author: '鲍勃', text: '扭蛋抽到隐藏款！开心～', likes: 12, date: new Date().toLocaleString() }
                    ];
                }
                renderComments();
            }

            function saveComments() {
                localStorage.setItem('minion_comments', JSON.stringify(comments));
                renderComments();
            }

            function renderComments() {
                const container = document.getElementById('commentListContainer');
                if (!container) return;
                if (comments.length === 0) {
                    container.innerHTML = '<div style="text-align:center; padding:30px; font-size:1.8rem;">🦻 还没有评论，说点啥吧～</div>';
                    return;
                }
                let html = '';
                // 按时间倒序 (最新的在前面)
                [...comments].sort((a,b) => b.id - a.id).forEach(c => {
                    html += `
                        <div class="comment-item" data-id="${c.id}">
                            <div class="comment-content">
                                <div class="comment-author"><i class="fa-regular fa-circle-user"></i> ${c.author}</div>
                                <div class="comment-text">${c.text}</div>
                                <div class="comment-date">${c.date}</div>
                            </div>
                            <div class="like-area">
                                <button class="like-btn" data-id="${c.id}"><i class="fa-regular fa-thumbs-up"></i> <span class="like-count">${c.likes}</span></button>
                            </div>
                        </div>
                    `;
                });
                container.innerHTML = html;

                // 绑定点赞事件
                document.querySelectorAll('.like-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        const id = parseInt(btn.getAttribute('data-id'));
                        const comment = comments.find(c => c.id === id);
                        if (comment) {
                            comment.likes = (comment.likes || 0) + 1;
                            saveComments();  // 保存并刷新
                        }
                    });
                });
            }

            // 发表评论
            document.getElementById('postCommentBtn').addEventListener('click', () => {
                const nameInput = document.getElementById('commentName');
                const textInput = document.getElementById('commentText');
                const author = nameInput.value.trim() || '匿名小黄人';
                const text = textInput.value.trim();
                if (!text) {
                    alert('写点内容再发射哟~');
                    return;
                }
                const newComment = {
                    id: Date.now(),
                    author: author,
                    text: text,
                    likes: 0,
                    date: new Date().toLocaleString('zh-CN', { hour12: false })
                };
                comments.push(newComment);
                saveComments();
                textInput.value = '';   // 清空内容，保留昵称
                // 可选保留昵称
            });

            // 初始化评论
            loadComments();

            // 初始渲染产品
            renderProducts();
            refreshCartUI(); // 空购物车

        })();
    </script>
</body>
</html>
